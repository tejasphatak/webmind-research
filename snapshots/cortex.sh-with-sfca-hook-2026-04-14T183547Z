update_faculty_weights() {
  # After a beat, update faculty weights based on outcome
  local result="$1"
  local json_line="$2"

  export _FW_RESULT="$result"
  export _FW_JSON="$json_line"
  python3 << 'PYEOF'
import json, os

FACULTIES = os.path.expanduser("~/cortex2/faculties.json")
result = os.environ.get("_FW_RESULT", "QUIET")
json_str = os.environ.get("_FW_JSON", "{}")

try:
    beat_data = json.loads(json_str)
    faculties_used = beat_data.get("faculties_used", [])
except Exception:
    faculties_used = []

if not faculties_used:
    exit(0)

try:
    with open(FACULTIES) as f:
        data = json.load(f)
except Exception:
    exit(0)

LEARN_RATE = 0.05  # How fast weights adapt
DECAY = 0.01       # Unused faculties slowly decay toward 0.5

for fac in data.get("faculties", []):
    name = fac["name"].lower()
    if name in [f.lower() for f in faculties_used]:
        fac["total_uses"] = fac.get("total_uses", 0) + 1
        if result == "ACTIVE":
            fac["active_outcomes"] = fac.get("active_outcomes", 0) + 1
            # Reward: weight moves toward 1.0
            fac["weight"] = min(1.0, fac.get("weight", 0.5) + LEARN_RATE)
        elif result == "BLOCKED":
            # Penalize slightly
            fac["weight"] = max(0.1, fac.get("weight", 0.5) - LEARN_RATE * 0.5)
        # QUIET: no change
    else:
        # Unused: slow decay toward 0.5 (regression to mean)
        w = fac.get("weight", 0.5)
        if w > 0.5:
            fac["weight"] = max(0.5, w - DECAY)
        elif w < 0.5:
            fac["weight"] = min(0.5, w + DECAY)

data["_meta"]["last_modified_beat"] = beat_data.get("beat", 0)

with open(FACULTIES, "w") as f:
    json.dump(data, f, indent=2)
PYEOF
  unset _FW_RESULT _FW_JSON
}

