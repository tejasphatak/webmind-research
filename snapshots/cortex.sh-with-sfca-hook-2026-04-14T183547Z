# ── Parse Beat Result ─────────────────────────────────────────────────
parse_beat_result() {
  local log_file="$1"

  # Try to extract JSON from the last few lines
  local json_line
  json_line=$(tail -20 "$log_file" 2>/dev/null | grep -oP '\{"action":"[^"]*".*\}' | tail -1 || echo "")

  if [ -z "$json_line" ]; then
    # Log what we got for debugging — first and last 200 chars
    local log_size_dbg
    log_size_dbg=$(wc -c < "$log_file" 2>/dev/null | tr -d '[:space:]')
    echo "[parse_beat_result] No JSON found in ${log_size_dbg}b output. First 200 chars: $(head -c 200 "$log_file" 2>/dev/null)" >> "$LOG_DIR/cortex.log"
  fi

  if [ -n "$json_line" ]; then
    # Parse the structured output
    local action summary ideas conv_update queue_response
    action=$(echo "$json_line" | jq -r '.action // "QUIET"' 2>/dev/null || echo "QUIET")
    summary=$(echo "$json_line" | jq -r '.summary // "no summary"' 2>/dev/null || echo "no summary")
    queue_response=$(echo "$json_line" | jq -r '.queue_response // empty' 2>/dev/null || echo "")

    # Save ideas if any
    local ideas_arr
    ideas_arr=$(echo "$json_line" | jq -r '.ideas // [] | length' 2>/dev/null || echo "0")
    if [ "$ideas_arr" -gt 0 ]; then
      local beat=$(sget beat 0)
      echo "$json_line" | python3 -c "
import json, sys, fcntl
line = json.load(sys.stdin)
ideas = line.get('ideas', [])
if ideas:
    beat = $beat
    faculties = line.get('faculties_used', [])
    with open('$IDEAS_FILE', 'r+') as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        existing = json.load(f)
        for idea in ideas:
            existing.append({'beat': beat, 'faculty': '+'.join(faculties), 'idea': idea, 'novelty': 0.5, 'promoted_to': None})
        f.seek(0)
        json.dump(existing, f, indent=2)
        f.truncate()
" 2>/dev/null || true
    fi

    # Handle convergence update
    echo "$json_line" | python3 -c "
import json, sys
line = json.load(sys.stdin)
update = line.get('convergence_update')
if update and isinstance(update, dict):
    cid = update.get('id')
    new_status = update.get('status')
    if cid and new_status:
        with open('$CONVERGENCE_FILE') as f:
            conv = json.load(f)
        for item in conv['items']:
            if item['id'] == cid:
                item['status'] = new_status
                item['updated_beat'] = $beat
        with open('$CONVERGENCE_FILE', 'w') as f:
            json.dump(conv, f, indent=2)
" 2>/dev/null || true

    # Update faculty weights based on outcome
    update_faculty_weights "$action" "$json_line"

    # Handle queue response — write to a file for the discord bot to pick up
    if [ -n "$queue_response" ]; then
      echo "$queue_response" > "$CORTEX_DIR/queue_response.txt"
    fi

    echo "$action"
    echo "$summary" > "$CORTEX_DIR/last_action.txt"
    # Save faculties_used for beat history tracking
    echo "$json_line" | jq -r '.faculties_used // [] | join("+")' > "$CORTEX_DIR/last_faculties.txt" 2>/dev/null || true

    # SFCA — Shapley Faculty Credit Assignment (P-SFC01)
    # Writes per-faculty credit to ledger DB for the A/B experiment + paper work.
    # Pure CPU, zero LLM quota, ~200ms.
    local sfca_faculties
    sfca_faculties=$(echo "$json_line" | jq -r '.faculties_used // [] | join(",")' 2>/dev/null)
    if [ -n "$sfca_faculties" ] && [ "$sfca_faculties" != "null" ] && [ "$action" != "QUIET" ]; then
      local beat_num
      beat_num=$(sget beat 0)
      python3 /home/tejasphatak/webmind-research/sfca/nexus_integration.py append \
        --beat-id "$beat_num" --outcome "$action" --faculties "$sfca_faculties" \
        --samples 300 \
        >> "$LOG_DIR/sfca.log" 2>&1 || true
    fi
  else
    # Fallback: check for beat_result.txt (backward compat)
    if [ -f "$BEAT_RESULT" ]; then
      cat "$BEAT_RESULT" | tr -d '[:space:]'
    elif [ "$(wc -c < "$log_file" 2>/dev/null | tr -d '[:space:]')" -gt 500 ]; then
      # Claude produced substantial output but no structured JSON — still did something
      echo "ACTIVE"
      echo "unstructured output ($(wc -c < "$log_file" | tr -d '[:space:]')b)" > "$CORTEX_DIR/last_action.txt"
    else
      echo "QUIET"
    fi
  fi
}

# ── Run One Beat ──────────────────────────────────────────────────────
run_beat() {
  local beat=$(sget beat 0)
  local log_file="$LOG_DIR/beat_${beat}.log"

  log "beat $beat starting (phase=$(sget phase) mood=$(sget mood_label) hope=$(sget hope) health=$(sget health))"

  # Clean previous
  rm -f "$BEAT_RESULT" "$CORTEX_DIR/last_action.txt" "$CORTEX_DIR/last_faculties.txt" "$CORTEX_DIR/queue_response.txt"

  local prompt
  prompt=$(build_prompt)

  # Call claude with full autonomy
  # Use stdbuf to force line-buffered stdout so output is captured even if timeout fires.
  # 480s timeout gives complex beats room to finish (was 300s — caused silent kills).
  local exit_code=0
  timeout 480 stdbuf -oL claude \
    -p "$prompt" \
    --permission-mode bypassPermissions \
    --model opus \
    < /dev/null \
    > "$log_file" 2>&1 || exit_code=$?

  local log_size
  log_size=$(wc -c < "$log_file" 2>/dev/null || echo "0")
  # Strip whitespace from wc output (some systems pad with spaces)
  log_size=$(echo "$log_size" | tr -d '[:space:]')
  log_size=${log_size:-0}

  log "beat $beat finished (exit=$exit_code, log=${log_size}b)"

  # Check for rate limiting — only match real rate-limit signals, not normal prose.
  # Use word-boundary-aware patterns to avoid false positives like "terminated" in "GPU node terminated".
  # Only flag if exit code was non-zero OR output is very short (likely an error message, not a real response).
  if [ "$exit_code" -ne 0 ] || [ "$log_size" -lt 500 ]; then
    if grep -qiP "rate.limit|HTTP 429|usage cap|too many requests|over capacity|API Error|throttl" "$log_file" 2>/dev/null; then
      local cooldown=$(($(date +%s) + 900))
      echo "$cooldown" > "$RATE_LIMIT_FILE"
      update_biostate "BLOCKED"
      log "beat $beat RATE LIMITED: $(head -1 "$log_file" 2>/dev/null)"
      remember_beat "$beat" "BLOCKED" "rate limited (exit=$exit_code)" ""
      return
    fi
  fi

  # Detect silent failures: 0-byte output or timeout
  if [ "$log_size" -lt 10 ]; then
    log "beat $beat EMPTY OUTPUT (${log_size}b) — Claude CLI produced no output"
    if [ "$exit_code" -eq 124 ]; then
      log "beat $beat timed out (480s)"
    elif [ "$exit_code" -ne 0 ]; then
      log "beat $beat non-zero exit: $exit_code"
    fi
    # Log system state for debugging
    log "beat $beat diag: claude_procs=$(pgrep -c claude 2>/dev/null || echo 0) mem_free=$(free -m 2>/dev/null | awk '/Mem:/{print $4}')MB disk=$(df -h / 2>/dev/null | awk 'NR==2{print $5}')"
    update_biostate "BLOCKED"
    remember_beat "$beat" "BLOCKED" "empty output (exit=$exit_code)" ""
    return
  fi

  # Parse structured output
  local result
  result=$(parse_beat_result "$log_file")
  result=${result:-QUIET}

  local action_summary="unknown"
  [ -f "$CORTEX_DIR/last_action.txt" ] && action_summary=$(head -1 "$CORTEX_DIR/last_action.txt")

  # Update bio-state (single source of truth — update_biostate function)
  update_biostate "$result"

  supdate ".last_action = \"$(echo "$action_summary" | head -c 200 | sed 's/"/\\"/g')\""

  # Memory: save beat to history + semantic memory if ACTIVE
  local faculties_str=""
  [ -f "$CORTEX_DIR/last_faculties.txt" ] && faculties_str=$(cat "$CORTEX_DIR/last_faculties.txt" | head -1)
  remember_beat "$beat" "$result" "$action_summary" "$faculties_str"

  # Memory: periodic re-index of markdown files into vector DB
  reindex_memory "$beat"

  # Self-repair: detect and fix death spirals
  self_repair "$beat"

  # Health check: real system diagnostics
  health_check "$beat"

  log "beat $beat $result: $action_summary"

  # Post to Discord every 5 successful beats
  if [ "$result" = "ACTIVE" ] && [ $(( $(sget total_beats 0) % 5 )) -eq 0 ]; then
    if [ -f "$CORTEX_DIR/../cortex/discord-post.py" ]; then
      python3 "$CORTEX_DIR/../cortex/discord-post.py" "Beat #$(sget beat 0): $action_summary" 2>/dev/null || true
    fi
  fi
}

# ── Main Loop ─────────────────────────────────────────────────────────
main() {
  init_state
  log "Nexus starting (PID $$)"
  echo "Nexus online. PID $$. State: $STATE_FILE"

  while true; do
    # Yield to interactive sessions (briefly — re-check often)
    if interactive_running; then
      log "interactive session active, sleeping 10s"
      sleep 10
      continue
    fi

    run_beat

    local delay=$(get_delay)
    log "next beat in ${delay}s (phase=$(sget phase) mood=$(sget mood_label) idle=$(sget idle))"

    # Sleep but wake early if urgent queue item arrives
    # Tight 1s tick for fast urgent response
    local slept=0
    while [ "$slept" -lt "$delay" ]; do
      sleep 1
      slept=$((slept + 1))
      # Check for urgent queue items
      if has_urgent_queue 2>/dev/null; then
        log "urgent queue item detected, waking early"
        break
      fi
      # Yield if interactive session starts
      if interactive_running; then
        break
      fi
    done
  done
}

main "$@"
