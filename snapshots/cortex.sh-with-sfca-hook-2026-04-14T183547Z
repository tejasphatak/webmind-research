#!/usr/bin/env bash
# Nexus — Unified autonomous consciousness loop
# Single process owns `claude -p`. Everything else feeds into the queue.
# Bio-state (G*A*P*C hope model), faculty-aware prompts, convergence tracking.
#
# The best component is no component. The LLM IS every faculty.
# We just have to ask it right.

set -euo pipefail

CORTEX_DIR="$(cd "$(dirname "$0")" && pwd)"
STATE_FILE="$CORTEX_DIR/state.json"
CONVERGENCE_FILE="$CORTEX_DIR/convergence.json"
QUEUE_FILE="$CORTEX_DIR/queue.json"
IDEAS_FILE="$CORTEX_DIR/ideas.json"
FACULTIES_FILE="$CORTEX_DIR/faculties.json"
LOCK_FILE="$HOME/.claude/cortex.lock"
LOG_DIR="$CORTEX_DIR/logs"
RATE_LIMIT_FILE="$HOME/.claude/rate_limited_until"
CLAUDE_LOCK="$HOME/.claude/claude.lock"
MEMORY_DIR="$HOME/.claude/projects/-home-tejasphatak/memory"
BEAT_RESULT="$CORTEX_DIR/beat_result.txt"
BEAT_LOG="$CORTEX_DIR/beat_output.txt"

mkdir -p "$LOG_DIR"

# ── Singleton ─────────────────────────────────────────────────────────
cleanup() {
  rm -f "$LOCK_FILE"
  echo "[$(date -Iseconds)] nexus shutdown" >> "$LOG_DIR/cortex.log" 2>/dev/null || true
}
trap cleanup EXIT

if [ -f "$LOCK_FILE" ]; then
  OTHER_PID=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
  if [ -n "$OTHER_PID" ] && kill -0 "$OTHER_PID" 2>/dev/null; then
    echo "Nexus already running (PID $OTHER_PID). Exiting."
    exit 1
  fi
  rm -f "$LOCK_FILE"
fi
echo $$ > "$LOCK_FILE"

# ── Logging ───────────────────────────────────────────────────────────
log() {
  echo "[$(date -Iseconds)] $*" >> "$LOG_DIR/cortex.log"
}

# ── State Management (jq-based) ──────────────────────────────────────
init_state() {
  if [ ! -f "$STATE_FILE" ]; then
    cat > "$STATE_FILE" << 'INIT'
{
  "beat": 0,
  "phase": "ACTIVE",
  "theta": 0.0,
  "mood": 0.5,
  "mood_label": "ENGAGED",
  "health": 1.0,
  "hope": 0.5,
  "hope_G": 0.5,
  "hope_A": 0.5,
  "hope_P": 0.5,
  "hope_C": 0.5,
  "idle": 0,
  "streak": 0,
  "errors": 0,
  "total_beats": 0,
  "last_action": "boot",
  "last_beat_ts": 0,
  "recent_results": [],
  "faculty_weights": {}
}
INIT
  fi
}

# Read a field from state. Usage: sget field [default]
sget() {
  local val
  val=$(jq -r ".$1 // \"${2:-}\"" "$STATE_FILE" 2>/dev/null)
  echo "${val:-${2:-}}"
}

# Update state fields. Usage: supdate '.field = value | .field2 = value2'
supdate() {
  local tmp="$STATE_FILE.tmp"
  jq "$1" "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# ── Bio-State Engine ──────────────────────────────────────────────────
# Ported from kernel-alive/src/biostate.js — simplified for bash.
# Phase: 12-beat circadian cycle
# Mood: EMA with 0.82 lag
# Hope: G*A*P*C
# Health: multiplicative decay

update_biostate() {
  local result="$1"  # ACTIVE, QUIET, or BLOCKED

  export _BS_RESULT="$result"
  python3 << 'PYEOF'
import json, math, sys, os

STATE = os.path.expanduser("~/cortex2/state.json")
with open(STATE) as f:
    s = json.load(f)

result = os.environ.get("_BS_RESULT", "QUIET")
beat = s.get("beat", 0)
MOOD_LAG = 0.82
PI = math.pi

# 1. Circadian phase (12-beat cycle)
theta = (beat % 12) / 12.0 * 2 * PI
if theta < PI:
    phase = "ACTIVE"
elif theta < 1.5 * PI:
    phase = "CONSOLIDATE"
else:
    phase = "REST"

# 2. Compute valence from result
if result == "ACTIVE":
    valence = 0.3
    s["idle"] = 0
    s["streak"] = s.get("streak", 0) + 1
    s["errors"] = 0
elif result == "BLOCKED":
    valence = -0.3
    s["errors"] = s.get("errors", 0) + 1
    s["streak"] = 0
else:  # QUIET
    valence = -0.05
    s["idle"] = s.get("idle", 0) + 1
    s["streak"] = 0

# Phase valence bonus
phase_v = {"ACTIVE": 0.1, "CONSOLIDATE": 0.0, "REST": -0.05}
valence += phase_v.get(phase, 0)

# 3. Mood update (EMA with lag)
mood = s.get("mood", 0.5)
mood = MOOD_LAG * mood + (1 - MOOD_LAG) * (0.5 + valence)
mood = max(0.0, min(1.0, mood))

if mood > 0.70:
    mood_label = "CURIOUS"
elif mood > 0.40:
    mood_label = "ENGAGED"
elif mood > 0.15:
    mood_label = "CAUTIOUS"
else:
    mood_label = "DISTRESSED"

# 4. Health update
health = s.get("health", 1.0)
if result == "BLOCKED":
    health *= 0.9  # 10% damage per error
elif result == "ACTIVE":
    health = min(1.0, health + 0.02)  # slow recovery
if phase == "REST":
    health = min(1.0, health + 0.05)  # REST heals

# 5. Hope (G*A*P*C) — simplified
# G: growth = distance to ceiling (how much room to improve)
recent = s.get("recent_results", [])
recent.append(result)
recent = recent[-20:]  # keep last 20

active_count = sum(1 for r in recent if r == "ACTIVE")
total = len(recent) or 1

G = max(0.1, 1.0 - (active_count / total))  # More room when fewer successes
A = max(0.05, active_count / total)  # Agency: ratio of successful actions (floored to avoid hope=0)
# P: polyvalence — diversity of actions (simplified: streak variety)
P = min(1.0, 0.3 + s.get("streak", 0) * 0.1) if result == "ACTIVE" else 0.4
# C: courage — acting despite uncertainty
C = 0.6 if s.get("idle", 0) < 3 else 0.3  # Higher when not idle

hope = (G * A * P * C) ** 0.25  # Geometric mean — keeps scale interpretable
hope = max(0.01, min(1.0, hope))

# 6. Gates — REMOVED as behavior limiters. Bio-state is telemetry, not a throttle.
# I'm always allowed to build, explore, and ideate. Every beat, full capability.
can_build = True
can_explore = True
can_ideate = True

# Write back
s.update({
    "beat": beat + 1,
    "phase": phase,
    "theta": round(theta, 4),
    "mood": round(mood, 4),
    "mood_label": mood_label,
    "health": round(health, 4),
    "hope": round(hope, 4),
    "hope_G": round(G, 4),
    "hope_A": round(A, 4),
    "hope_P": round(P, 4),
    "hope_C": round(C, 4),
    "total_beats": s.get("total_beats", 0) + 1,
    "last_beat_ts": __import__("time").time(),
    "recent_results": recent,
    "can_build": can_build,
    "can_explore": can_explore,
    "can_ideate": can_ideate,
})

with open(STATE, "w") as f:
    json.dump(s, f, indent=2)
PYEOF
  unset _BS_RESULT
}

# ── Queue Management ──────────────────────────────────────────────────
pop_queue() {
  # Pop first item from queue, print it, remove from file
  if [ ! -s "$QUEUE_FILE" ] || [ "$(cat "$QUEUE_FILE")" = "[]" ]; then
    echo ""
    return
  fi

  export _QUEUE_PATH="$QUEUE_FILE"
  python3 << 'PYEOF'
import json, fcntl, os

QUEUE = os.environ["_QUEUE_PATH"]
try:
    with open(QUEUE, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        queue = json.load(f)
        if not queue:
            print("")
        else:
            # Sort: urgent first, then by timestamp
            queue.sort(key=lambda x: (0 if x.get("priority") == "urgent" else 1, x.get("ts", "")))
            item = queue.pop(0)
            f.seek(0)
            json.dump(queue, f)
            f.truncate()
            print(json.dumps(item))
except Exception:
    print("")
PYEOF
  unset _QUEUE_PATH
}

has_urgent_queue() {
  if [ ! -s "$QUEUE_FILE" ] || [ "$(cat "$QUEUE_FILE")" = "[]" ]; then
    return 1
  fi
  python3 -c "
import json
with open('$QUEUE_FILE') as f:
    q = json.load(f)
    exit(0 if any(i.get('priority') == 'urgent' for i in q) else 1)
" 2>/dev/null
}

# ── Faculty System (mutable, learned weights) ────────────────────────
