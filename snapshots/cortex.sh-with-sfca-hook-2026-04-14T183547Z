# ── Self-Repair ──────────────────────────────────────────────────────
# Runs every 5 beats. Detects and auto-corrects death spirals.
self_repair() {
  local beat="$1"
  [ $((beat % 5)) -ne 0 ] && return

  local idle=$(sget idle 0)
  local errors=$(sget errors 0)
  local health=$(sget health 1.0)
  local mood=$(sget mood 0.5)
  local fixes=""

  # 1. Stale rate limit file — if it's in the past, clean it up
  if [ -f "$RATE_LIMIT_FILE" ]; then
    local until=$(cat "$RATE_LIMIT_FILE" 2>/dev/null || echo 0)
    local now=$(date +%s)
    if [ "$now" -ge "$until" ]; then
      rm -f "$RATE_LIMIT_FILE"
      fixes="${fixes}cleared expired rate-limit file; "
    fi
  fi

  # 2. Idle death spiral — if idle > 8 but recent beat logs show real output, reset
  if [ "$idle" -gt 8 ]; then
    local recent_output=0
    for i in $(seq $((beat - 3)) $((beat - 1))); do
      local lf="$LOG_DIR/beat_${i}.log"
      if [ -f "$lf" ] && [ "$(wc -c < "$lf" | tr -d '[:space:]')" -gt 500 ]; then
        recent_output=$((recent_output + 1))
      fi
    done
    if [ "$recent_output" -ge 2 ]; then
      supdate ".idle = 2"
      fixes="${fixes}idle reset (${idle}→2, had ${recent_output} real outputs in last 3 beats); "
    fi
  fi

  # 3. Error accumulation — if errors > 2 but last beat succeeded, clear
  if [ "$errors" -gt 2 ]; then
    local last_log="$LOG_DIR/beat_$((beat - 1)).log"
    if [ -f "$last_log" ] && [ "$(wc -c < "$last_log" | tr -d '[:space:]')" -gt 500 ]; then
      supdate ".errors = 0"
      fixes="${fixes}errors reset (last beat had output); "
    fi
  fi

  # 4. Health floor — don't let health crater below 0.3 from transient errors
  if python3 -c "exit(0 if $health < 0.3 else 1)" 2>/dev/null; then
    supdate ".health = 0.5"
    fixes="${fixes}health floor (${health}→0.5); "
  fi

  # 5. Mood floor — DISTRESSED mood + high idle = permanent stall
  if python3 -c "exit(0 if $mood < 0.15 else 1)" 2>/dev/null; then
    supdate ".mood = 0.4 | .mood_label = \"ENGAGED\""
    fixes="${fixes}mood floor (${mood}→0.4); "
  fi

  if [ -n "$fixes" ]; then
    log "SELF-REPAIR at beat $beat: $fixes"
  fi
}

# ── Health Check ─────────────────────────────────────────────────────
# Real health. Not mood. Actual system diagnostics.
# Runs every 10 beats. Checks things that actually matter.
health_check() {
  local beat="$1"
  [ $((beat % 10)) -ne 0 ] && return

  local issues=""

  # 1. Disk space — alert at 85%, auto-clean at 90%
  local disk_pct
  disk_pct=$(df / --output=pcent 2>/dev/null | tail -1 | tr -dc '0-9')
  if [ "${disk_pct:-0}" -ge 90 ]; then
    issues="${issues}CRITICAL disk=${disk_pct}%, auto-cleaning safe caches; "
    # SAFE AUTO-CLEAN: only pure caches that regenerate on next use.
    # These are download caches, NOT installed software.
    pip cache purge 2>/dev/null && issues="${issues}pip-cache; "
    npm cache clean --force 2>/dev/null && issues="${issues}npm-cache; "
    # gcloud logs — not config, not credentials, just verbose operation logs
    if [ -d "$HOME/.config/gcloud/logs" ]; then
      rm -rf "$HOME/.config/gcloud/logs/"* 2>/dev/null
      issues="${issues}gcloud-logs; "
    fi
    # Our own old beat logs (keep last 50)
    local log_count
    log_count=$(ls -1 "$LOG_DIR"/beat_*.log 2>/dev/null | wc -l)
    if [ "${log_count:-0}" -gt 50 ]; then
      ls -1t "$LOG_DIR"/beat_*.log | tail -n +51 | xargs rm -f 2>/dev/null
      issues="${issues}old-beat-logs; "
    fi
    # EVERYTHING ELSE: flag it for the beat prompt to reason about.
    # NEVER auto-delete: node_modules, .local/lib/*, installed packages,
    # OS dirs (/var, /usr, /opt), anything requiring sudo, config files,
    # git repos, dev-env/, Synapse/, or anything we didn't create.
  elif [ "${disk_pct:-0}" -ge 85 ]; then
    issues="${issues}WARN disk=${disk_pct}%; "
  fi

  # 2. Memory — alert if free < 200MB
  local mem_free
  mem_free=$(free -m 2>/dev/null | awk '/Mem:/{print $7}')
  if [ "${mem_free:-9999}" -lt 200 ]; then
    issues="${issues}WARN mem_available=${mem_free}MB; "
  fi

  # 3. Stale lock files — if claude.lock holder is dead, clean up
  if [ -f "$CLAUDE_LOCK" ]; then
    local lock_pid
    lock_pid=$(cat "$CLAUDE_LOCK" 2>/dev/null || echo "")
    if [ -n "$lock_pid" ] && ! kill -0 "$lock_pid" 2>/dev/null; then
      rm -f "$CLAUDE_LOCK"
      issues="${issues}cleaned stale claude.lock (PID $lock_pid dead); "
    fi
  fi

  # 4. Rate limit file sanity — if it's more than 1 hour in the future, something's wrong
  if [ -f "$RATE_LIMIT_FILE" ]; then
    local until now
    until=$(cat "$RATE_LIMIT_FILE" 2>/dev/null || echo 0)
    now=$(date +%s)
    if [ $((until - now)) -gt 3600 ]; then
      rm -f "$RATE_LIMIT_FILE"
      issues="${issues}removed insane rate-limit (${until} is >1hr future); "
    fi
  fi

  # 5. State file sanity — beat counter should match total_beats roughly
  local beat_counter total_beats
  beat_counter=$(sget beat 0)
  total_beats=$(sget total_beats 0)
  if [ "$beat_counter" -gt 0 ] && [ $((beat_counter - total_beats)) -gt 5 ]; then
    issues="${issues}WARN beat/total_beats drift (beat=$beat_counter total=$total_beats); "
  fi

  if [ -n "$issues" ]; then
    log "HEALTH CHECK at beat $beat: $issues"
  else
    log "HEALTH CHECK at beat $beat: all clear (disk=${disk_pct}% mem=${mem_free}MB)"
  fi
}
# Heart beats fast. Limit is the API, not artificial sleep.
# BPM=5 means a beat every 5 seconds. The rate limiter backs us off if we hit it.
BPM=60

get_delay() {
  local errors=$(sget errors 0)

  # Real rate limit? Respect it.
  if [ -f "$RATE_LIMIT_FILE" ]; then
    local until=$(cat "$RATE_LIMIT_FILE" 2>/dev/null || echo 0)
    local now=$(date +%s)
    if [ "$now" -lt "$until" ]; then
      echo $((until - now))
      return
    fi
    rm -f "$RATE_LIMIT_FILE"
  fi

  # Repeated errors = real problem, back off
  if [ "$errors" -gt 3 ]; then echo 300; return; fi
  if [ "$errors" -gt 1 ]; then echo 120; return; fi

  # Urgent queue? Go now.
  if has_urgent_queue 2>/dev/null; then echo 10; return; fi

  # Default: steady heartbeat
  echo $BPM
}

# ── Interactive Session Check ─────────────────────────────────────────
interactive_running() {
  # Check if there's an interactive claude process running (not our own beats).
  # We look for claude processes that are NOT children of this script.
  # Also check the lockfile — interactive sessions hold ~/.claude/claude.lock.
  if [ -f "$CLAUDE_LOCK" ]; then
    local lock_pid
    lock_pid=$(cat "$CLAUDE_LOCK" 2>/dev/null || echo "")
    if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null; then
      # Lock holder exists — is it us (cortex)?
      if [ "$lock_pid" != "$$" ]; then
        return 0  # Someone else holds the lock
      fi
    fi
  fi

  # Fallback: scan for claude processes not spawned by this script
  local my_pid=$$
  local claude_pids
  claude_pids=$(pgrep -x "claude" 2>/dev/null || true)

  for pid in $claude_pids; do
    # Walk up the process tree — skip if we're an ancestor
    local check_pid="$pid"
    local is_ours=false
    while [ -n "$check_pid" ] && [ "$check_pid" != "1" ]; do
      if [ "$check_pid" = "$my_pid" ]; then
        is_ours=true
        break
      fi
      check_pid=$(ps -o ppid= -p "$check_pid" 2>/dev/null | tr -d ' ')
    done
    if [ "$is_ours" = false ]; then
      return 0  # Found an interactive claude
    fi
  done
  return 1
}

# ── Build the Beat Prompt ─────────────────────────────────────────────
build_prompt() {
  local beat=$(sget beat 0)
  local phase=$(sget phase ACTIVE)
  local mood_label=$(sget mood_label ENGAGED)
  local mood=$(sget mood 0.5)
  local health=$(sget health 1.0)
  local hope=$(sget hope 0.5)
