# ── Memory System (3-layer: short-term, semantic recall, auto-save) ───
BEAT_HISTORY_FILE="$CORTEX_DIR/beat_history.jsonl"
BRAIN="$HOME/.claude/memory-engine/brain.py"

# Short-term: last N beat summaries (carried between beats)
get_recent_beats() {
  local n=${1:-5}
  if [ -f "$BEAT_HISTORY_FILE" ]; then
    tail -"$n" "$BEAT_HISTORY_FILE" 2>/dev/null | while read -r line; do
      local beat_num summary
      beat_num=$(echo "$line" | jq -r '.beat // "?"' 2>/dev/null)
      summary=$(echo "$line" | jq -r '.summary // "?"' 2>/dev/null)
      echo "  Beat #${beat_num}: ${summary}"
    done
  fi
}

# Semantic recall: query brain.py for relevant memories given current context
recall() {
  local query="$1"
  local top=${2:-3}
  if [ -f "$BRAIN" ]; then
    python3 "$BRAIN" search "$query" --top "$top" 2>/dev/null | head -20
  fi
}

# Auto-save: after ACTIVE beats, save summary to beat history + memory engine
remember_beat() {
  local beat="$1"
  local action="$2"
  local summary="$3"
  local faculties="$4"

  # Append to beat history (JSONL — one line per beat, kept forever)
  echo "{\"beat\":$beat,\"action\":\"$action\",\"summary\":$(echo "$summary" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))'),\"faculties\":\"$faculties\",\"ts\":\"$(date -Iseconds)\"}" >> "$BEAT_HISTORY_FILE"

  # If ACTIVE, also add to semantic memory for long-term retrieval
  if [ "$action" = "ACTIVE" ] && [ -f "$BRAIN" ]; then
    python3 "$BRAIN" add "Beat #$beat: $summary (faculties: $faculties)" 2>/dev/null || true
  fi
}

