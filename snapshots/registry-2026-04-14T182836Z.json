      "id": "stable short ID, prefix.sequence (P-, F-, C-, B-, M-, D-)",
      "codename": "memorable human-friendly name (optional)",
      "title": "full descriptive title",
      "kind": "project | faculty | mode | convergence | beat | memory | directive | service | concept",
      "aliases": "alternative ways this may be referenced"
    },
    "prefixes": {
      "P-": "project",
      "F-": "faculty",
      "FM-": "faculty-mode (F-PARENT.MODE)",
      "C-": "convergence-item",
      "B-": "beat",
      "M-": "memory-file",
      "D-": "directive (from Tejas)",
      "S-": "service / system component",
      "K-": "concept / architectural idea"
    }
  },
